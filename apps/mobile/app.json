{
  "expo": {
    "name": "Timviz Master",
    "slug": "timviz-master",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/timviz-icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/timviz-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.timviz.master"
    },
    "android": {
      "package": "com.timviz.master",
      "adaptiveIcon": {
        "foregroundImage": "./assets/timviz-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "appEnv": "production"
    },
    "plugins": [
      "expo-localization"
    ]
  }
}
